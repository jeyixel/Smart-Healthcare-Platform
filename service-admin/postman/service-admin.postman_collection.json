  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Admin Service Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{adminBaseUrl}}/actuator/health",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Patient Actions",
      "item": [
        {
          "name": "Set Patient Active",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.collectionVariables.set('patientId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-Admin-User",
                "value": "{{adminUser}}"
              }
            ],
            "url": {
              "raw": "{{adminBaseUrl}}/api/v1/admin/patients/{{patientId}}/status?active=true",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "patients",
                "{{patientId}}",
                "status"
              ],
              "query": [
                {
                  "key": "active",
                  "value": "true"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Set Patient Inactive",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-Admin-User",
                "value": "{{adminUser}}"
              }
            ],
            "url": {
              "raw": "{{adminBaseUrl}}/api/v1/admin/patients/{{patientId}}/status?active=false",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "patients",
                "{{patientId}}",
                "status"
              ],
              "query": [
                {
                  "key": "active",
                  "value": "false"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Prescription Snapshot",
      "item": [
        {
          "name": "Upsert Prescription Snapshot",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Admin-User",
                "value": "{{adminUser}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"externalPrescriptionId\": \"RX-ADMIN-2026-001\",\n  \"doctorId\": \"DOC-001\",\n  \"medicationSummary\": \"Paracetamol 500mg twice daily for 3 days\",\n  \"issuedDate\": \"2026-03-30\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{adminBaseUrl}}/api/v1/admin/prescription-snapshots",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "prescription-snapshots"
              ]
            }
          },
          "response": []
